</div>

<script>
(function(){
  // ====== TUKAR NOMBOR WHATSAPP DI SINI (format antarabangsa, tanpa +) ======
  var WA_NUMBER = "60145651872";
  // =========================================================================

  var waMsg = "Salam, saya ada soalan / nak order Jus Aurora Kasih.";
  var waBtn = document.getElementById("jauf-wa-btn");
  if(waBtn){ waBtn.setAttribute("href", "https://wa.me/" + WA_NUMBER + "?text=" + encodeURIComponent(waMsg)); }

  // accordion FAQ
  document.querySelectorAll("#jauf-root .jauf-item").forEach(function(item){
    var q = item.querySelector(".jauf-q");
    var a = item.querySelector(".jauf-a");
    q.addEventListener("click", function(){
      var open = item.classList.contains("on");
      document.querySelectorAll("#jauf-root .jauf-item").forEach(function(it){
        it.classList.remove("on");
        it.querySelector(".jauf-a").style.maxHeight = null;
      });
      if(!open){
        item.classList.add("on");
        a.style.maxHeight = a.scrollHeight + "px";
      }
    });
  });
})();
</script>
