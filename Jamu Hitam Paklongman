<script>
(function(){
  // ====== TUKAR NOMBOR WHATSAPP DI SINI (format antarabangsa, tanpa +) ======
  var WA_NUMBER = "60145651872";
  // =========================================================================

  var PKGS = [
    { name:"1 Paket Jamu Hitam",  desc:"Sesuai untuk cuba & rasa sendiri", price:45, count:1, tag:null },
    { name:"2 Paket Jamu Hitam",  desc:"Stok untuk amalan berterusan",     price:55, count:2, tag:null },
    { name:"3 Paket Jamu Hitam",  desc:"Amalan konsisten 3 bulan",          price:60, count:3, tag:null },
    { name:"Pakej Super Berbaloi",desc:"3 Paket Jamu + 1 FREE GIFT",        price:65, count:3, tag:"PALING POPULAR" },
    { name:"Pakej Jimat",         desc:"3 Paket Jamu + 2 FREE GIFT",        price:70, count:3, tag:"PALING BERBALOI" }
  ];
  var sel = 3;
  var money = function(n){ return "$" + n.toFixed(2); };

  var wrap = document.getElementById("jpl-pkgs");
  PKGS.forEach(function(p, i){
    var unit = p.count > 1 ? ("≈ " + money(p.price/p.count) + " / paket") : "Cuba dulu";
    var tag = p.tag ? '<span style="font-size:9px;font-weight:800;letter-spacing:.03em;color:#fff;background:#111;padding:3px 7px;border-radius:20px">'+p.tag+'</span>' : '';
    var el = document.createElement("div");
    el.className = "jpl-card" + (i===sel ? " on" : "");
    el.setAttribute("data-i", i);
    el.innerHTML =
      '<div class="jpl-radio"></div>' +
      '<div style="flex:1;min-width:0"><div style="display:flex;align-items:center;gap:7px;flex-wrap:wrap"><span style="font-weight:700;font-size:14px">'+p.name+'</span>'+tag+'</div>' +
      '<div style="font-size:12px;color:#7a7a7a;margin-top:3px">'+p.desc+'</div></div>' +
      '<div style="text-align:right"><div style="font-weight:800;font-size:15.5px">'+money(p.price)+'</div><div style="font-size:9.5px;color:#a3a3a3">'+unit+'</div></div>';
    el.addEventListener("click", function(){ sel = i; render(); });
    wrap.appendChild(el);
  });

  function render(){
    var p = PKGS[sel];
    document.querySelectorAll("#jpl-pkgs .jpl-card").forEach(function(c){
      c.className = "jpl-card" + (parseInt(c.getAttribute("data-i"),10)===sel ? " on" : "");
    });
    document.getElementById("jpl-selname").textContent = p.name;
    document.getElementById("jpl-total").textContent  = money(p.price);
    document.getElementById("jpl-total2").textContent = money(p.price);
    var cta = document.getElementById("jpl-cta");
    cta.textContent = "ORDER VIA WHATSAPP · " + money(p.price) + " →";
    var msg = "Salam, saya nak order " + p.name + " (" + money(p.price) + ") secara COD.";
    cta.href = "https://wa.me/" + WA_NUMBER + "?text=" + encodeURIComponent(msg);
  }
  render();

  // countdown 2 jam
  var end = Date.now() + 2*3600*1000;
  var cd = document.getElementById("jpl-cd");
  function tick(){
    var s = Math.max(0, Math.floor((end - Date.now())/1000));
    var p = function(n){ return (n<10?"0":"") + n; };
    cd.textContent = p(Math.floor(s/3600)) + ":" + p(Math.floor((s%3600)/60)) + ":" + p(s%60);
  }
  tick(); setInterval(tick, 1000);
})();
</script>
