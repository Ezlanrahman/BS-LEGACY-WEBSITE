<script>
(function(){
  // ====== TETAPAN ======
  var CHECKOUT_ID = "order";        // id form checkout
  var WA_NUMBER   = "60145651872";  // no WhatsApp
  var WA_PATH     = "jusauroramy";  // path link wasap.my (boleh kosongkan)
  // =====================

  document.querySelectorAll("#jau-root .jau-checkout").forEach(function(a){
    a.setAttribute("href", "#" + CHECKOUT_ID);
    a.addEventListener("click", function(e){
      var target = document.getElementById(CHECKOUT_ID);
      if(target){ e.preventDefault(); target.scrollIntoView({ behavior:"smooth", block:"start" }); }
    });
  });

  var wa = document.getElementById("jau-wa-btn");
  if(wa){ wa.setAttribute("href", "https://wa.me/" + WA_NUMBER + "?text=" + encodeURIComponent("Salam, saya berminat dengan Jus Aurora Kasih.")); }

  // carousel testimoni — dot indicator
  (function(){
    var track = document.getElementById("jau-testi-track");
    var dotsWrap = document.getElementById("jau-testi-dots");
    if(!track || !dotsWrap) return;
    var slides = track.querySelectorAll(".jau-slide");
    slides.forEach(function(_, i){
      var d = document.createElement("div");
      d.className = "jau-dot" + (i===0 ? " on" : "");
      d.addEventListener("click", function(){
        track.scrollTo({ left: slides[i].offsetLeft - track.offsetLeft, behavior:"smooth" });
      });
      dotsWrap.appendChild(d);
    });
    var dots = dotsWrap.querySelectorAll(".jau-dot");
    var raf;
    track.addEventListener("scroll", function(){
      if(raf) return;
      raf = requestAnimationFrame(function(){
        raf = null;
        var center = track.scrollLeft + track.clientWidth/2;
        var best = 0, bestDist = Infinity;
        slides.forEach(function(s, i){
          var sc = s.offsetLeft + s.clientWidth/2;
          var dist = Math.abs(sc - center);
          if(dist < bestDist){ bestDist = dist; best = i; }
        });
        dots.forEach(function(d, i){ d.className = "jau-dot" + (i===best ? " on" : ""); });
      });
    });
  })();

  // countdown header (marquee) — 2 jam
  var end = Date.now() + 2*3600*1000;
  var cds = document.querySelectorAll(".jau-cd");
  function tick(){
    var s = Math.max(0, Math.floor((end - Date.now())/1000));
    var p = function(n){ return (n<10?"0":"") + n; };
    var txt = p(Math.floor(s/3600)) + ":" + p(Math.floor((s%3600)/60)) + ":" + p(s%60);
    cds.forEach(function(el){ el.textContent = txt; });
  }
  tick(); setInterval(tick, 1000);

  // countdown block — ke tengah malam
  var h2el = document.getElementById("jau-cd2-h");
  var m2el = document.getElementById("jau-cd2-m");
  var s2el = document.getElementById("jau-cd2-s");
  if(h2el && m2el && s2el){
    var pad = function(n){ return (n<10?"0":"") + n; };
    function tick2(){
      var now = new Date();
      var mid = new Date(now.getFullYear(), now.getMonth(), now.getDate()+1, 0, 0, 0, 0);
      var s = Math.max(0, Math.floor((mid - now)/1000));
      h2el.textContent = pad(Math.floor(s/3600));
      m2el.textContent = pad(Math.floor((s%3600)/60));
      s2el.textContent = pad(s%60);
    }
    tick2(); setInterval(tick2, 1000);
  }
})();
</script>
