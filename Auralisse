    <!-- LETAK FORM CHECKOUT CARTFLOWS DI SINI (dalam WordPress) -->
    <!-- (FAQ, CTA & footer diletak sebagai widget berasingan di BAWAH form) -->

    <script>
        // Reveal-on-scroll
        const io = new IntersectionObserver((entries) => {
            entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
        }, { threshold: 0.12 });
        document.querySelectorAll('.reveal').forEach(el => io.observe(el));

        // Countdown timer (6 jam, disimpan dalam sesi pelawat)
        (function () {
            const DURATION = 6 * 60 * 60 * 1000; // 6 jam
            let end = sessionStorage.getItem('auralisse_cd_end');
            if (!end) { end = Date.now() + DURATION; sessionStorage.setItem('auralisse_cd_end', end); }
            end = parseInt(end, 10);
            const h = document.querySelector('[data-cd="h"]');
            const m = document.querySelector('[data-cd="m"]');
            const s = document.querySelector('[data-cd="s"]');
            function tick() {
                let diff = end - Date.now();
                if (diff < 0) { end = Date.now() + DURATION; sessionStorage.setItem('auralisse_cd_end', end); diff = DURATION; }
                const hrs = Math.floor(diff / 3600000);
                const mins = Math.floor((diff % 3600000) / 60000);
                const secs = Math.floor((diff % 60000) / 1000);
                if (h) h.textContent = String(hrs).padStart(2, '0');
                if (m) m.textContent = String(mins).padStart(2, '0');
                if (s) s.textContent = String(secs).padStart(2, '0');
            }
            tick();
            setInterval(tick, 1000);
        })();

        // Carousel feedback
        (function () {
            const track = document.getElementById('fbTrack');
            if (!track) return;
            const step = () => {
                const card = track.querySelector('div');
                return card ? card.getBoundingClientRect().width + 20 : track.clientWidth * 0.8;
            };
            const prev = document.getElementById('fbPrev');
            const next = document.getElementById('fbNext');
            if (prev) prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
            if (next) next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
        })();
    </script>

